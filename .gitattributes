# Normalize text files to LF in repository and working tree by default
* text=auto eol=lf

# Keep Windows script files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
